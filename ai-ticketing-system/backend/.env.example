# AI Ticketing System — Environment Variables
# Copy this file to .env and fill in your API keys

# Groq API Key (primary — fast LLM inference via Groq cloud)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic Claude API Key (optional — fallback if Groq unavailable)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Database
DATABASE_URL=sqlite:///./ticketing.db
